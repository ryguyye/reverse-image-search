# Copy to .env and fill in keys for the providers you want to enable.
# The app only calls providers that have a key configured.

# SerpAPI — used for Google Lens and Yandex Images.
# Get a key at https://serpapi.com/
SERPAPI_KEY=

# TinEye MatchEngine / Search API.
# Get a key at https://services.tineye.com/
TINEYE_API_KEY=

# Optional: cap the number of results merged per provider (default 25).
MAX_RESULTS_PER_PROVIDER=25

# Optional: HTTP request timeout in seconds (default 30).
HTTP_TIMEOUT=30
