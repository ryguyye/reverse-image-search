# Copy to .env and fill in keys for the providers you want to enable.
# The app only calls providers that have a key configured.

# SerpAPI — used for Google Lens and Yandex Images.
# Get a key at https://serpapi.com/
SERPAPI_KEY=

# TinEye Search API. Both the public and private keys are required —
# requests are signed with HMAC-SHA256.
# Get keys at https://services.tineye.com/
TINEYE_API_KEY=
TINEYE_PRIVATE_KEY=

# Optional: cap the number of results merged per provider (default 25).
MAX_RESULTS_PER_PROVIDER=25

# Optional: HTTP request timeout in seconds (default 30).
HTTP_TIMEOUT=30

# Where the SQLite database for watches lives (default ./selfwatch.db).
DB_PATH=selfwatch.db

# Public base URL of this app. Required if you want recurring scans of
# uploaded images — providers fetch the image at PUBLIC_BASE_URL/uploads/<name>.
# Most users: a Cloudflare Tunnel URL (see docs/deploy.md).
#   Quick:  https://wandering-orange-fox-1234.trycloudflare.com  (ephemeral)
#   Named:  https://selfwatch.yourdomain.com                     (stable)
PUBLIC_BASE_URL=

# How often the scheduler ticks for due watches, in seconds (default 60).
SCHEDULER_TICK_SECONDS=60

# Webhook POST timeout in seconds (default 10).
WEBHOOK_TIMEOUT=10

# Minimum allowed cadence for a watch, in minutes (default 5). Guard against
# burning provider quota on too-frequent rescans.
MIN_CADENCE_MINUTES=5
